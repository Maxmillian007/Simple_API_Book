              "pm.test('Response is JSON object and captures orderId if present', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('object');",
              "    if (jsonData && (jsonData.orderId || jsonData.id)) {",
              "        const oid = jsonData.orderId || jsonData.id;",
              "        pm.collectionVariables.set('orderId', oid);",
              "        pm.expect(pm.collectionVariables.get('orderId')).to.eql(oid);",
              "    }",
              "})"
