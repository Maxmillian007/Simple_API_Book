    {
      "name": "Register API Client",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", () => {",
              "    pm.response.to.have.status(201);",
              "})",
              "",
              "pm.test('Status code is 200 or 201', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([",
              "        200,",
              "        201",
              "    ]);",
              "})",
              "",
              "",
              "pm.test('If accessToken present, capture it into collection variable', function () {",
              "    if (pm.response.code === 204)",
              "        return;",
              "    let jsonData;",
              "    try {",
              "        jsonData = pm.response.json();",
              "    } catch (e) {",
              "        return;",
              "    }",
              "    if (jsonData && jsonData.accessToken) {",
              "        pm.collectionVariables.set('accessToken', jsonData.accessToken);",
              "        pm.expect(pm.collectionVariables.get('accessToken')).to.eql(jsonData.accessToken);",
              "    }",
              "})",
              "",
              "pm.test('Response time is under 3000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
